<RT3>
    <camera type="perspective" fovy="45" />
    <integrator type="blinn" depth="3" />
    <film type="image" w_res="1920" h_res="1200" filename="neon_night.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <!-- Céu noturno: roxo escuro embaixo, quase preto no topo -->
        <background type="colors" bl="10 0 20" tl="2 0 10" tr="2 0 10" br="10 0 20" />

        <!-- Ambient mínimo, cor levemente roxa -->
        <light_source type="ambient" I="0.05 0.01 0.1" scale="1 1 1" />

        <!-- Luzes coloridas posicionadas onde estão as esferas neon -->
        <light_source type="point" I="0.0 1.0 0.85" scale="3.5 3.5 3.5" from="-4.5 2.0 2.5" />   <!-- Cyan -->
        <light_source type="point" I="1.0 0.0 0.55" scale="3.5 3.5 3.5" from=" 4.5 2.0 2.5" />   <!-- Magenta -->
        <light_source type="point" I="0.5 1.0 0.0"  scale="2.5 2.5 2.5" from=" 0.0 3.0 6.0" />   <!-- Verde limão -->
        <light_source type="point" I="1.0 0.35 0.0" scale="2.0 2.0 2.0" from="-2.0 1.5 0.5" />   <!-- Laranja -->
        <light_source type="point" I="0.2 0.2 1.0"  scale="2.0 2.0 2.0" from=" 2.5 1.5 0.5" />   <!-- Azul elétrico -->

        <!-- ===== CHÃO: espelho escuro reflexivo ===== -->
        <make_named_material type="blinn" name="dark_mirror_floor"
            ambient="0.03 0.01 0.06"
            diffuse="0.04 0.01 0.08"
            specular="0.95 0.92 0.98"
            glossiness="1024"/>
        <named_material name="dark_mirror_floor"/>
        <object type="sphere" center="0 -5000 0" radius="5000" />

        <!-- ===== ESFERA CENTRAL: espelho escuro grande ===== -->
        <!-- Vai refletir todas as luzes coloridas ao redor -->
        <make_named_material type="blinn" name="obsidian_mirror"
            ambient="0.05 0.02 0.08"
            diffuse="0.08 0.03 0.12"
            specular="0.97 0.95 0.99"
            glossiness="2048"/>
        <named_material name="obsidian_mirror"/>
        <object type="sphere" center="0 2.2 4.5" radius="2.0" />

        <!-- ===== ESFERA NEON CYAN (esquerda) ===== -->
        <!-- Núcleo brilhante (flat = emissivo) -->
        <material type="flat" color="0 255 220" />
        <object type="sphere" center="-4.5 2.0 2.5" radius="0.35" />
        <!-- Corpo principal -->
        <make_named_material type="blinn" name="neon_cyan"
            ambient="0.0 0.25 0.22"
            diffuse="0.0 0.65 0.75"
            specular="0.7 1.0 1.0"
            glossiness="512"/>
        <named_material name="neon_cyan"/>
        <object type="sphere" center="-4.5 1.1 2.5" radius="1.1" />

        <!-- ===== ESFERA NEON MAGENTA (direita) ===== -->
        <material type="flat" color="255 0 130" />
        <object type="sphere" center="4.5 2.0 2.5" radius="0.35" />
        <make_named_material type="blinn" name="neon_magenta"
            ambient="0.28 0.0 0.14"
            diffuse="0.82 0.0 0.42"
            specular="1.0 0.7 0.88"
            glossiness="512"/>
        <named_material name="neon_magenta"/>
        <object type="sphere" center="4.5 1.1 2.5" radius="1.1" />

        <!-- ===== ESFERA NEON VERDE (ao fundo, centro) ===== -->
        <material type="flat" color="130 255 0" />
        <object type="sphere" center="0.0 3.0 6.0" radius="0.28" />
        <make_named_material type="blinn" name="neon_lime"
            ambient="0.14 0.28 0.0"
            diffuse="0.38 0.82 0.0"
            specular="0.85 1.0 0.7"
            glossiness="256"/>
        <named_material name="neon_lime"/>
        <object type="sphere" center="0.0 1.8 6.5" radius="1.2" />

        <!-- ===== ESFERA NEON LARANJA (pequena, frente-esquerda) ===== -->
        <material type="flat" color="255 100 0" />
        <object type="sphere" center="-2.0 1.5 0.5" radius="0.22" />
        <make_named_material type="blinn" name="neon_orange"
            ambient="0.3 0.1 0.0"
            diffuse="0.88 0.38 0.0"
            specular="1.0 0.75 0.5"
            glossiness="256"/>
        <named_material name="neon_orange"/>
        <object type="sphere" center="-2.0 0.7 0.5" radius="0.7" />

        <!-- ===== ESFERA NEON AZUL (pequena, frente-direita) ===== -->
        <material type="flat" color="80 80 255" />
        <object type="sphere" center="2.5 1.5 0.5" radius="0.22" />
        <make_named_material type="blinn" name="neon_blue"
            ambient="0.08 0.08 0.38"
            diffuse="0.15 0.15 0.88"
            specular="0.7 0.7 1.0"
            glossiness="512"/>
        <named_material name="neon_blue"/>
        <object type="sphere" center="2.5 0.7 0.5" radius="0.7" />

        <!-- ===== PARTÍCULAS / ESTRELAS flutuantes ===== -->
        <material type="flat" color="0 255 220" />
        <object type="sphere" center="-7.0 4.5 8.0"  radius="0.06" />
        <object type="sphere" center="-5.5 6.0 12.0" radius="0.05" />
        <material type="flat" color="255 0 130" />
        <object type="sphere" center=" 7.0 5.0 9.0"  radius="0.06" />
        <object type="sphere" center=" 5.0 7.0 14.0" radius="0.05" />
        <material type="flat" color="130 255 0" />
        <object type="sphere" center="-3.0 8.0 15.0" radius="0.05" />
        <object type="sphere" center=" 4.0 5.5 11.0" radius="0.04" />
        <material type="flat" color="255 255 255" />
        <object type="sphere" center=" 1.0 9.0 18.0" radius="0.04" />
        <object type="sphere" center="-4.0 7.0 16.0" radius="0.03" />

    <world_end/>
</RT3>
