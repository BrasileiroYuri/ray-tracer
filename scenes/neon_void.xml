    <film type="image" w_res="1920" h_res="1080" filename="neon_void.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors"
            bl="2 0 8"
            tl="120 0 255"
            tr="0 255 200"
            br="5 0 15" />

        <light_source type="ambient"
            I="0.04 0.04 0.08"
            scale="1 1 1" />

        <light_source type="spot"
            I="1 0 1"
            scale="1 1 1"
            from="-8 10 -6"
            to="-2 1 2"
            cutoff="18"
            falloff="8" />

        <light_source type="spot"
            I="0 1 1"
            scale="1 1 1"
            from="8 12 -2"
            to="2 1 4"
            cutoff="18"
            falloff="8" />

        <make_named_material type="blinn" name="pink"
            ambient="0.2 0.05 0.2"
            diffuse="1 0 0.7"
            specular="1 1 1"
            glossiness="512"/>

        <make_named_material type="blinn" name="cyan"
            ambient="0.05 0.2 0.2"
            diffuse="0 1 1"
            specular="1 1 1"
            glossiness="512"/>

        <make_named_material type="blinn" name="purple"
            ambient="0.15 0.05 0.25"
            diffuse="0.5 0 1"
            specular="1 1 1"
            glossiness="128"/>

        <make_named_material type="blinn" name="floor"
            ambient="0.05 0.05 0.08"
            diffuse="0.25 0.25 0.35"
            specular="0.2 0.2 0.3"
            glossiness="32"/>

        <named_material name="floor"/>
        <object type="plane" point="0 0 0" normal="0 1 0"/>

        <named_material name="pink"/>
        <object type="sphere" center="-4 1 1" radius="1"/>

        <named_material name="cyan"/>
        <object type="sphere" center="4 1 3" radius="1"/>

        <named_material name="purple"/>
        <object type="sphere" center="0 3 5" radius="2"/>

    <world_end/>
</RT3>