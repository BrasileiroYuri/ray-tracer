<RT3>
    <lookat look_from="0 12 -20" look_at="0 0 5" up="0 1 0" />
    <camera type="perspective" fovy="50" />
    <integrator type="blinn_phong" depth="2" />
    <film type="image" w_res="1920" h_res="1080" filename="solar_system.png" img_type="png" gamma_corrected="false" />
    <aggregator type="list"/>
    <world_begin/>

        <background type="single_color" color="0 0 0"/>

        <!-- Sol: luz pontual central + ambient fraquíssimo -->
        <light_source type="ambient"   I="0.05 0.05 0.05" scale="1 1 1" />
        <light_source type="point"     I="1.0 0.95 0.8"   scale="1.5 1.5 1.5" from="0 0 0" />

        <!-- Chão como plano negro (espaço) -->
        <!-- Sol -->
        <make_named_material type="blinn" name="sun"
            ambient="1.0 0.8 0.0"
            diffuse="1.0 0.7 0.0"
            specular="1.0 1.0 0.5"
            glossiness="8"
            mirror="0 0 0"/>

        <!-- Mercúrio: cinza escuro, sem brilho -->
        <make_named_material type="blinn" name="mercury"
            ambient="0.3 0.3 0.3"
            diffuse="0.5 0.5 0.5"
            specular="0.2 0.2 0.2"
            glossiness="4"
            mirror="0 0 0"/>

        <!-- Vênus: amarelado com brilho difuso -->
        <make_named_material type="blinn" name="venus"
            ambient="0.5 0.4 0.1"
            diffuse="0.9 0.8 0.3"
            specular="0.6 0.6 0.4"
            glossiness="16"
            mirror="0 0 0"/>

        <!-- Terra: azul com reflexo -->
        <make_named_material type="blinn" name="earth"
            ambient="0.05 0.1 0.3"
            diffuse="0.1 0.4 0.9"
            specular="0.8 0.8 0.8"
            glossiness="64"
            mirror="0.1 0.1 0.15"/>

        <!-- Lua: branca fosca -->
        <make_named_material type="blinn" name="moon"
            ambient="0.2 0.2 0.2"
            diffuse="0.7 0.7 0.7"
            specular="0.1 0.1 0.1"
            glossiness="2"
            mirror="0 0 0"/>

        <!-- Marte: vermelho -->
        <make_named_material type="blinn" name="mars"
            ambient="0.4 0.1 0.05"
            diffuse="0.8 0.2 0.1"
            specular="0.3 0.1 0.1"
            glossiness="8"
            mirror="0 0 0"/>

        <!-- Júpiter: laranja listrado (aproximado) -->
        <make_named_material type="blinn" name="jupiter"
            ambient="0.4 0.25 0.1"
            diffuse="0.8 0.55 0.3"
            specular="0.5 0.4 0.2"
            glossiness="16"
            mirror="0 0 0"/>

        <!-- Saturno: dourado fosco -->
        <make_named_material type="blinn" name="saturn"
            ambient="0.4 0.35 0.15"
            diffuse="0.85 0.75 0.4"
            specular="0.4 0.35 0.2"
            glossiness="8"
            mirror="0 0 0"/>

        <!-- Anel de Saturno (esfera achatada — z_min/z_max) -->
        <make_named_material type="blinn" name="ring"
            ambient="0.3 0.25 0.1"
            diffuse="0.6 0.55 0.3"
            specular="0.2 0.2 0.1"
            glossiness="2"
            mirror="0 0 0"/>

        <!-- Sol no centro -->
        <named_material name="sun"/>
        <object type="sphere" center="0 0 0" radius="2.0" />

        <!-- Mercúrio -->
        <named_material name="mercury"/>
        <object type="sphere" center="3.5 0 0" radius="0.25" />

        <!-- Vênus -->
        <named_material name="venus"/>
        <object type="sphere" center="5.2 0 0" radius="0.45" />

        <!-- Terra -->
        <named_material name="earth"/>
        <object type="sphere" center="7.2 0 0" radius="0.5" />

        <!-- Lua (orbita a Terra) -->
        <named_material name="moon"/>
        <object type="sphere" center="7.9 0.3 -0.8" radius="0.13" />

        <!-- Marte -->
        <named_material name="mars"/>
        <object type="sphere" center="9.5 0 1.0" radius="0.35" />

        <!-- Júpiter -->
        <named_material name="jupiter"/>
        <object type="sphere" center="13.0 0 3.0" radius="1.2" />

        <!-- Saturno -->
        <named_material name="saturn"/>
        <object type="sphere" center="17.0 0 6.0" radius="1.0" />

        <!-- Anel de Saturno (esfera grande e achatada) -->
        <named_material name="ring"/>
        <object type="sphere" center="17.0 0 6.0" radius="1.8" z_min="-0.18" z_max="0.18" />

    <world_end/>
</RT3>
