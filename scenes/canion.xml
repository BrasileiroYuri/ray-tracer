<RT3>
    <lookat look_from="0 2 -15" look_at="0 2 0" up="0 1 0" />
    <camera type="perspective" fovy="40" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="cena9_canion.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="5 2 2" tl="10 5 5" tr="10 5 5" br="5 2 2" />
        <light_source type="ambient" I="0.5 0.2 0.2" scale="1.1 1.1 1.1" />

        <light_source type="spot" I="2.0 1.5 1.0" scale="1 1 1" from="0 2 20" to="0 2 -10" cutoff="25" falloff="15" />

        <make_named_material type="blinn" name="dark_wall" ambient="0.05 0.05 0.05" diffuse ="0.1 0.1 0.1" specular ="0.8 0.8 0.8" glossiness ="256"/>
        <make_named_material type="blinn" name="floor_tile" ambient="0.1 0.1 0.1" diffuse ="0.4 0.4 0.4" specular ="0.5 0.5 0.5" glossiness ="64"/>
        <make_named_material type="blinn" name="gold_sphere" ambient="0.2 0.2 0.2" diffuse ="1.0 0.7 0.0" specular ="1.0 0.9 0.5" glossiness ="512"/>

        <named_material name="floor_tile"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <named_material name="dark_wall"/>
        <object type="cube" p1="-5 0 -10" p2="-1.5 10 15" />

        <named_material name="dark_wall"/>
        <object type="cube" p1="1.5 0 -10" p2="5 10 15" />

        <named_material name="gold_sphere"/>
        <object type="sphere" center="0 2 -5" radius="0.3" /> <object type="sphere" center="0 2 2" radius="0.5" />  <object type="sphere" center="0 2 10" radius="1.2" /> <world_end/>
</RT3>
