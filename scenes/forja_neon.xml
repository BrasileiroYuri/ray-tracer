        <named_material name="dark_mirror"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <named_material name="glossy_grey"/>

        <object type="cube" p1="-2 0 -2" p2="2 4 2" />

        <object type="cube" p1="-5 1 -1" p2="-3 3 1" />
        <object type="cube" p1="3 1 -1" p2="5 3 1" />
        <object type="cube" p1="-1 1 3" p2="1 3 5" />
        <object type="cube" p1="-1 1 -5" p2="1 3 -3" />

        <object type="sphere" center="0 5 0" radius="1.5" />
        <object type="sphere" center="0 2 0" radius="1.0" /> <world_end/>
</RT3>
