    <film type="image" w_res="1920" h_res="1200" filename="cena16_forja_neon.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="0 0 0" tl="10 10 10" tr="10 10 10" br="0 0 0" />

        <light_source type="ambient" I="0.1 0.1 0.1" scale="1.5 1.5 1.5" />

        <light_source type="spot" I="2.0 1.8 0.5" scale="1 1 1" from="0 10 10" to="0 0 -5" cutoff="30" falloff="15" />

        <light_source type="spot" I="0.5 3.0 3.0" scale="1 1 1" from="10 1 0" to="0 1 0" cutoff="60" falloff="40" /> <light_source type="spot" I="3.0 0.5 2.0" scale="1 1 1" from="-10 1 0" to="0 1 0" cutoff="60" falloff="40" /> <light_source type="spot" I="0.6 0.6 0.6" scale="1 1 1" from="0 4 -12" to="0 0 0" cutoff="70" falloff="50" />

