<RT3>
    <lookat look_from="0 2 -12" look_at="0 2 10" up="0 1 0" />
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="cena5_corredor.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="0 0 0" tl="0 0 0" tr="0 0 0" br="0 0 0" />
        <light_source type="ambient" I="0.05 0.05 0.05" scale="0.5 0.5 0.5" />

        <light_source type="spot" I="0.8 0.8 0.9" scale="1 1 1" from="0 7 -6" to="0 0 -6" cutoff="25" falloff="15" />
        <light_source type="spot" I="0.8 0.8 0.9" scale="1 1 1" from="0 7 0"  to="0 0 0"  cutoff="25" falloff="15" />
        <light_source type="spot" I="1.0 0.8 0.3" scale="1 1 1" from="0 7 8"  to="0 2 8"  cutoff="20" falloff="5" />

        <make_named_material type="blinn" name="concrete" ambient="0.1 0.1 0.1" diffuse ="0.6 0.6 0.6" specular ="0.2 0.2 0.2" glossiness ="16"/>
        <make_named_material type="blinn" name="gold_obj" ambient="0.4 0.4 0.4" diffuse ="1.0 0.7 0.1" specular ="0.9 0.8 0.2" glossiness ="256"/>

        <named_material name="concrete"/>
        <object type="plane" point="0 0 0" normal="0 1 0" /> <object type="cube" p1="-4 0 -8" p2="-3 6 -6" />
        <object type="cube" p1="-4 0 -2" p2="-3 6 0" />
        <object type="cube" p1="-4 0 4"  p2="-3 6 6" />

        <object type="cube" p1="3 0 -8" p2="4 6 -6" />
        <object type="cube" p1="3 0 -2" p2="4 6 0" />
        <object type="cube" p1="3 0 4"  p2="4 6 6" />

        <named_material name="gold_obj"/>
        <object type="sphere" center="0 2 8" radius="1.5" />

    <world_end/>
</RT3>
