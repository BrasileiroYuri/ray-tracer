<RT3>
    <!-- Robô Retro: câmera levemente lateral e elevada -->
    <lookat look_from="5 10 -16" look_at="0 5 2" up="0 1 0" />
    <camera type="perspective" fovy="42" />
    <integrator type="blinn_phong" depth="2" />
    <film type="image" w_res="1920" h_res="1200" filename="robo.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <background type="colors" bl="30 30 45" tl="10 12 28" tr="10 12 28" br="30 30 45" />

        <light_source type="ambient" I="0.08 0.08 0.12" scale="1 1 1" />
        <light_source type="directional" I="0.85 0.88 0.95" scale="1.0 1.0 1.0" from="-4 8 -3" to="0 0 1" />
        <light_source type="point" I="0.4 0.6 1.0" scale="2.0 2.0 2.0" from="0 9 1" />
        <light_source type="point" I="0.9 0.6 0.2" scale="1.2 1.2 1.2" from="6 6 -2" />
        <light_source type="point" I="0.2 0.8 0.4" scale="0.8 0.8 0.8" from="-5 4 4" />

        <!-- Materiais -->
        <make_named_material type="blinn" name="robot_body"
            ambient="0.08 0.08 0.12" diffuse="0.3 0.32 0.42" specular="0.85 0.88 0.95" glossiness="512"/>
        <make_named_material type="blinn" name="robot_dark"
            ambient="0.04 0.04 0.06" diffuse="0.12 0.12 0.18" specular="0.6 0.6 0.7" glossiness="256"/>
        <make_named_material type="blinn" name="robot_gold"
            ambient="0.22 0.16 0.0" diffuse="0.9 0.7 0.08" specular="0.95 0.8 0.4" glossiness="512"/>
        <make_named_material type="blinn" name="robot_red"
            ambient="0.2 0.02 0.02" diffuse="0.88 0.06 0.06" specular="0.95 0.8 0.8" glossiness="256"/>
        <make_named_material type="blinn" name="floor_metal"
            ambient="0.04 0.04 0.06" diffuse="0.12 0.12 0.15" specular="0.7 0.7 0.75" glossiness="256"/>

        <named_material name="floor_metal"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <!-- Grade do chão -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-6.04 0.001 -5" p2="-5.96 0.04 12" />
        <object type="cube" p1="-5.04 0.001 -5" p2="-4.96 0.04 12" />
        <object type="cube" p1="-4.04 0.001 -5" p2="-3.96 0.04 12" />
        <object type="cube" p1="-3.04 0.001 -5" p2="-2.96 0.04 12" />
        <object type="cube" p1="-2.04 0.001 -5" p2="-1.96 0.04 12" />
        <object type="cube" p1="-1.04 0.001 -5" p2="-0.96 0.04 12" />
        <object type="cube" p1="-0.04 0.001 -5" p2="0.04 0.04 12" />
        <object type="cube" p1="0.96 0.001 -5" p2="1.04 0.04 12" />
        <object type="cube" p1="1.96 0.001 -5" p2="2.04 0.04 12" />
        <object type="cube" p1="2.96 0.001 -5" p2="3.04 0.04 12" />
        <object type="cube" p1="3.96 0.001 -5" p2="4.04 0.04 12" />
        <object type="cube" p1="4.96 0.001 -5" p2="5.04 0.04 12" />
        <object type="cube" p1="5.96 0.001 -5" p2="6.04 0.04 12" />
        <object type="cube" p1="-6 0.001 -1.04" p2="6 0.04 -0.96" />
        <object type="cube" p1="-6 0.001 -0.04" p2="6 0.04 0.04" />
        <object type="cube" p1="-6 0.001 0.96" p2="6 0.04 1.04" />
        <object type="cube" p1="-6 0.001 1.96" p2="6 0.04 2.04" />
        <object type="cube" p1="-6 0.001 2.96" p2="6 0.04 3.04" />
        <object type="cube" p1="-6 0.001 3.96" p2="6 0.04 4.04" />
        <object type="cube" p1="-6 0.001 4.96" p2="6 0.04 5.04" />
        <object type="cube" p1="-6 0.001 5.96" p2="6 0.04 6.04" />
        <object type="cube" p1="-6 0.001 6.96" p2="6 0.04 7.04" />

        <!-- ============================== -->
        <!-- ROBÔ CENTRAL                   -->
        <!-- ============================== -->

        <!-- PERNAS -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-1.2 0 -0.5" p2="-0.3 3.5 0.5" />
        <object type="cube" p1=" 0.3 0 -0.5" p2=" 1.2 3.5 0.5" />
        <!-- Pés -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-1.4 0 -0.8" p2="-0.1 0.5 0.9" />
        <object type="cube" p1=" 0.1 0 -0.8" p2=" 1.4 0.5 0.9" />
        <!-- Joelhos -->
        <named_material name="robot_gold"/>
        <object type="sphere" center="-0.75 2.0 0" radius="0.32" />
        <object type="sphere" center=" 0.75 2.0 0" radius="0.32" />

        <!-- CINTURA / QUADRIL -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-1.5 3.2 -0.6" p2="1.5 4.0 0.6" />
        <named_material name="robot_gold"/>
        <object type="cube" p1="-1.6 3.5 -0.55" p2="1.6 3.75 0.55" />

        <!-- TORSO -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-1.8 4.0 -0.8" p2="1.8 8.0 0.8" />
