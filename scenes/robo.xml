        <material type="flat" color="255 50 50" />
        <object type="sphere" center="-0.75 13.6 0" radius="0.2" />
        <material type="flat" color="50 255 100" />
        <object type="sphere" center=" 0.75 13.9 0" radius="0.2" />

        <!-- ===== ROBÔ 2 ao fundo (menor, distante) ===== -->
        <!-- Robozinho de fundo -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="4.42 0 5.70" p2="6.58 2.10 6.30" />
        <named_material name="robot_body"/>
        <object type="cube" p1="4.42 1.92 5.52" p2="6.58 4.80 6.48" />
        <object type="cube" p1="4.60 5.28 5.40" p2="6.40 6.90 6.60" />
        <object type="cube" p1="5.20 4.80 5.76" p2="5.80 5.28 6.24" />
        <material type="flat" color="255 100 50" />
        <object type="sphere" center="5.17 6.06 5.37" radius="0.19" />
        <object type="sphere" center="5.83 6.06 5.37" radius="0.19" />

    <world_end/>
</RT3>