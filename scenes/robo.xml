        <object type="sphere" center="-2.4 8.2 0" radius="0.45" />
        <object type="sphere" center=" 2.4 8.2 0" radius="0.45" />

        <!-- BRAÇOS -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-3.2 4.5 -0.45" p2="-2.0 7.2 0.45" />
        <object type="cube" p1=" 2.0 4.5 -0.45" p2=" 3.2 7.2 0.45" />
        <!-- Cotovelos -->
        <named_material name="robot_gold"/>
        <object type="sphere" center="-2.6 4.8 0" radius="0.35" />
        <object type="sphere" center=" 2.6 4.8 0" radius="0.35" />
        <!-- Antebraços -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-3.4 2.2 -0.4" p2="-1.8 5.0 0.4" />
        <object type="cube" p1=" 1.8 2.2 -0.4" p2=" 3.4 5.0 0.4" />
        <!-- Pulsos -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-3.3 1.8 -0.38" p2="-1.9 2.3 0.38" />
        <object type="cube" p1=" 1.9 1.8 -0.38" p2=" 3.3 2.3 0.38" />
        <!-- Mãos / Garras -->
        <named_material name="robot_gold"/>
        <object type="cube" p1="-3.5 0.8 -0.5" p2="-1.7 1.9 0.5" />
        <object type="cube" p1=" 1.7 0.8 -0.5" p2=" 3.5 1.9 0.5" />
        <!-- Dedos -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-3.60 0.2 -0.5" p2="-1.60 0.85 -0.25" />
        <object type="cube" p1="-3.60 0.2 -0.1" p2="-1.60 0.85 0.15" />
        <object type="cube" p1="-3.60 0.2 0.3" p2="-1.60 0.85 0.55" />
        <object type="cube" p1="1.60 0.2 -0.5" p2="3.60 0.85 -0.25" />
        <object type="cube" p1="1.60 0.2 -0.1" p2="3.60 0.85 0.15" />
        <object type="cube" p1="1.60 0.2 0.3" p2="3.60 0.85 0.55" />

        <!-- PESCOÇO -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-0.5 8.0 -0.4" p2="0.5 8.8 0.4" />
        <named_material name="robot_gold"/>
        <object type="cube" p1="-0.55 8.3 -0.44" p2="0.55 8.55 0.44" />

        <!-- CABEÇA -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-1.5 8.8 -1.0" p2="1.5 11.5 1.0" />
        <!-- Viseira -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-1.3 9.5 -1.05" p2="1.3 10.8 -0.7" />
        <!-- OLHOS (emissivos, brilhantes) -->
        <material type="flat" color="80 200 255" />
        <object type="sphere" center="-0.55 10.1 -1.05" radius="0.32" />
        <object type="sphere" center=" 0.55 10.1 -1.05" radius="0.32" />
        <!-- Pupila dos olhos -->
        <material type="flat" color="0 80 180" />
        <object type="sphere" center="-0.55 10.1 -1.08" radius="0.18" />
        <object type="sphere" center=" 0.55 10.1 -1.08" radius="0.18" />
        <!-- Boca / grade -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-0.8 9.0 -1.04" p2="0.8 9.4 -0.72" />
        <named_material name="robot_gold"/>
        <object type="cube" p1="-0.6 9.02 -1.06" p2="-0.45 9.38 -0.7" />
        <object type="cube" p1="-0.2 9.02 -1.06" p2="-0.05 9.38 -0.7" />
        <object type="cube" p1="0.2 9.02 -1.06" p2="0.35 9.38 -0.7" />
        <object type="cube" p1="0.6 9.02 -1.06" p2="0.75 9.38 -0.7" />
