        <named_material name="robot_gold"/>
        <object type="cube" p1="-1.1 5.2 -0.87" p2="1.1 5.35 -0.66" />
        <object type="cube" p1="-1.1 5.6 -0.87" p2="1.1 5.75 -0.66" />
