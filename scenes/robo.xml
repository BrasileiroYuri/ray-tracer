        <material type="flat" color="60 255 60" />
        <object type="sphere" center=" 0.0 7.0 -0.9" radius="0.15" />
        <material type="flat" color="60 120 255" />
        <object type="sphere" center=" 0.7 7.0 -0.9" radius="0.15" />
