        <named_material name="robot_body"/>
        <object type="cube" p1="-1.85 9.8 -0.3" p2="-1.5 10.8 0.3" />
        <object type="cube" p1=" 1.5  9.8 -0.3" p2=" 1.85 10.8 0.3" />
        <!-- Antenas -->
        <named_material name="robot_dark"/>
        <object type="cube" p1="-0.85 11.5 -0.1" p2="-0.65 13.5 0.1" />
        <object type="cube" p1=" 0.65 11.5 -0.1" p2=" 0.85 13.8 0.1" />
