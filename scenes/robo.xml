        <material type="flat" color="255 200 50" />
        <object type="sphere" center="0 5.8 -0.88" radius="0.28" />

        <!-- OMBROS / PAULDRONS -->
        <named_material name="robot_body"/>
        <object type="cube" p1="-3.0 7.0 -0.7" p2="-1.8 8.2 0.7" />
        <object type="cube" p1=" 1.8 7.0 -0.7" p2=" 3.0 8.2 0.7" />
