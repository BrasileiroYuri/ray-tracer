    <aggregator type="list"/>

    <world_begin/>

        <background type="colors" bl="250 250 250" tl="220 220 220" tr="220 220 220" br="250 250 250" />

        <light_source type="ambient" I="0.2 0.2 0.2" scale="0.8 0.8 0.8" />

