<RT3>
    <lookat look_from="0 7 -24" look_at="0 5 8" up="0 1 0" />
    <camera type="perspective" fovy="38" />
    <integrator type="blinn_phong" depth="2" />
    <film type="image" w_res="1920" h_res="1200" filename="orbital_dock.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <background type="colors" bl="2 4 12" tl="12 18 35" tr="6 10 24" br="2 4 12" />

        <light_source type="ambient" I="0.05 0.06 0.08" scale="1 1 1" />
        <light_source type="directional" I="0.75 0.8 0.9" scale="1 1 1" from="-2 4 -3" to="0 0 1" />
        <light_source type="point" I="0.3 0.9 1.0" scale="3 3 3" from="-8 10 2" />
        <light_source type="point" I="1.0 0.6 0.2" scale="2 2 2" from="7 6 12" />
        <light_source type="point" I="0.6 0.2 1.0" scale="2.5 2.5 2.5" from="0 12 18" />

        <make_named_material type="blinn" name="dock_metal"
            ambient="0.05 0.05 0.06" diffuse="0.24 0.26 0.3" specular="0.92 0.92 0.96" glossiness="512"/>
        <make_named_material type="blinn" name="dock_dark"
            ambient="0.02 0.02 0.03" diffuse="0.08 0.09 0.12" specular="0.7 0.72 0.78" glossiness="256"/>
        <make_named_material type="blinn" name="dock_gold"
            ambient="0.18 0.14 0.03" diffuse="0.85 0.68 0.15" specular="0.95 0.82 0.4" glossiness="1024"/>
        <make_named_material type="blinn" name="dock_blue"
            ambient="0.03 0.05 0.08" diffuse="0.16 0.28 0.45" specular="0.9 0.95 1.0" glossiness="1024"/>

        <named_material name="dock_dark"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <!-- main station ring -->
        <named_material name="dock_metal"/>
        <object type="cube" p1="-7 2.8 4.0" p2="7 3.4 5.0"/>
        <object type="cube" p1="-7 2.8 11.0" p2="7 3.4 12.0"/>
        <object type="cube" p1="-7 2.8 4.0" p2="-6 3.4 12.0"/>
        <object type="cube" p1="6 2.8 4.0" p2="7 3.4 12.0"/>

        <!-- central hub -->
        <named_material name="dock_gold"/>
        <object type="sphere" center="0 3.2 8" radius="1.4"/>
        <named_material name="dock_blue"/>
        <object type="sphere" center="0 3.2 8" radius="0.7"/>

        <!-- docking arms -->
        <named_material name="dock_metal"/>
        <object type="cube" p1="-0.6 3.4 -4" p2="0.6 5.8 2.5"/>
        <object type="cube" p1="-0.4 5.2 2.5" p2="0.4 6.2 10.5"/>
        <object type="cube" p1="-2.8 5.1 8.8" p2="2.8 5.9 9.6"/>

        <!-- modules -->
        <object type="cube" p1="-4.5 1.4 0.5" p2="-2.2 4.0 2.8"/>
        <object type="cube" p1="2.2 1.4 0.5" p2="4.5 4.2 2.8"/>
        <object type="cube" p1="-4.5 1.4 13.2" p2="-2.2 4.0 15.5"/>
        <object type="cube" p1="2.2 1.4 13.2" p2="4.5 4.2 15.5"/>

        <!-- antennae -->
        <named_material name="dock_dark"/>
        <object type="cube" p1="-0.2 6.2 7.7" p2="0.2 10.5 8.3"/>
        <object type="cube" p1="-0.9 9.8 7.95" p2="0.9 10.2 8.05"/>

        <!-- satellites -->
        <named_material name="dock_blue"/>
        <object type="sphere" center="-9 7 6" radius="0.9"/>
        <object type="sphere" center="9 6 10" radius="0.8"/>
        <object type="sphere" center="0 10 14" radius="0.7"/>
        <object type="sphere" center="-6 4 15" radius="0.6"/>

        <!-- floor detail blocks -->
        <named_material name="dock_dark"/>
        <object type="cube" p1="-10 0.0 -2" p2="-8 0.25 18"/>
        <object type="cube" p1="8 0.0 -2" p2="10 0.25 18"/>
        <object type="cube" p1="-10 0.0 -2" p2="10 0.25 0"/>
        <object type="cube" p1="-10 0.0 16" p2="10 0.25 18"/>

        <!-- energy cores -->
        <named_material name="dock_gold"/>
        <object type="sphere" center="-6 2.0 8" radius="0.45"/>
        <object type="sphere" center=" 6 2.0 8" radius="0.45"/>
        <object type="sphere" center="0 5.2 8" radius="0.35"/>

    <world_end/>
</RT3>
