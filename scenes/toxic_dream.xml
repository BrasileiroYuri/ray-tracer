<RT3>
    <lookat look_from="-10 6 -16" look_at="0 1 2" up="0 1 0" />
    <camera type="perspective" fovy="42" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1080" filename="toxic_dream.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors"
            bl="10 30 0"
            tl="120 255 0"
            tr="255 120 0"
            br="30 10 0"/>

        <light_source type="ambient"
            I="0.06 0.06 0.04"
            scale="1 1 1"/>

        <light_source type="spot"
            I="0.4 1 0"
            scale="1 1 1"
            from="-12 12 -5"
            to="-2 1 2"
            cutoff="22"
            falloff="14"/>

        <light_source type="spot"
            I="1 0.4 0"
            scale="1 1 1"
            from="12 10 0"
            to="4 1 4"
            cutoff="18"
            falloff="10"/>

        <make_named_material type="blinn" name="acid"
            ambient="0.15 0.2 0.05"
            diffuse="0.7 1 0"
            specular="1 1 0.6"
            glossiness="256"/>

        <make_named_material type="blinn" name="lava"
            ambient="0.2 0.08 0.02"
            diffuse="1 0.3 0"
            specular="1 0.8 0.3"
            glossiness="128"/>

        <make_named_material type="blinn" name="slime"
            ambient="0.05 0.15 0.05"
            diffuse="0.1 0.8 0.2"
            specular="0.9 1 0.9"
            glossiness="64"/>

        <make_named_material type="blinn" name="floor"
            ambient="0.08 0.08 0.05"
            diffuse="0.35 0.35 0.25"
            specular="0.15 0.15 0.10"
            glossiness="8"/>

        <named_material name="floor"/>
        <object type="plane" point="0 0 0" normal="0 1 0"/>

        <named_material name="acid"/>
        <object type="sphere" center="-5 1 0" radius="1"/>

        <named_material name="lava"/>
        <object type="sphere" center="0 2 3" radius="2"/>

        <named_material name="slime"/>
        <object type="sphere" center="5 1 5" radius="1"/>

        <named_material name="acid"/>
        <object type="sphere" center="0 5 8" radius="1.2"/>

    <world_end/>
</RT3>