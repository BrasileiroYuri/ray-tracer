<RT3>
    <lookat look_from="0 2 -10" look_at="0 0 0" up="0 1 0" />
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="vazio_geometrico.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>

    <world_begin/>

        <background type="4_colors" bl="0 0 0" tl="5 5 10" tr="5 5 10" br="0 0 0" />

        <light_source type="ambient" I="0.01 0.01 0.01" scale="1 1 1" />

        <light_source type="spot" I="1.0 0.1 0.9" scale="1 1 1" from="0 7 0" to="0 0 0" cutoff="25" falloff="15" />

        <light_source type="spot" I="0.1 1.0 1.0" scale="1 1 1" from="0 -7 0" to="0 0 0" cutoff="25" falloff="15" />

        <light_source type="spot" I="1.0 1.0 0.1" scale="1 1 1" from="0 0 7" to="0 0 0" cutoff="25" falloff="15" />

        <make_named_material type="blinn" name="void_redish"     ambient="0.6 0.6 0.6" diffuse ="0.9 0.1 0.1"   specular ="0.8 0.8 0.8" glossiness ="64"/>
        <make_named_material type="blinn" name="void_greenish"   ambient="0.6 0.6 0.6" diffuse ="0.1 0.9 0.1"   specular ="0.8 0.8 0.8" glossiness ="256"/>
        <make_named_material type="blinn" name="void_blueish"    ambient="0.6 0.6 0.6" diffuse ="0.1 0.1 0.9"   specular ="0.8 0.8 0.8" glossiness ="16"/>
        <make_named_material type="blinn" name="void_gold"       ambient="0.4 0.4 0.4" diffuse ="1.0 0.6 0.0"   specular ="0.8 0.6 0.2" glossiness ="256"/>

        <named_material name="void_gold"/>
        <object type="cube" p1="-1 -1 -1" p2="1 1 1" />

        <named_material name="void_redish"/>
        <object type="sphere" center="-1.2 1.2 0" radius="1.0" />

        <named_material name="void_greenish"/>
        <object type="sphere" center="1.2 1.2 0" radius="1.0" />

        <named_material name="void_blueish"/>
        <object type="sphere" center="0 -1.8 0" radius="1.0" />

1       <named_material name="void_redish"/>
        <object type="cube" p1="1.8 1.8 1.8" p2="2.3 2.3 2.3" />

        <named_material name="void_blueish"/>
        <object type="cube" p1="-2.3 -2.3 -2.3" p2="-1.8 -1.8 -1.8" />

    <world_end/>
</RT3>
