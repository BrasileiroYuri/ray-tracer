<RT3>
    <lookat look_from="0 10 -10" look_at="0 0 0" up="0 1 0" />
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="sombras_rgb.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="0 0 0" tl="0 0 0" tr="0 0 0" br="0 0 0" />

        <light_source type="ambient" I="0 0 0" scale="0 0 0" />

        <light_source type="spot" I="1.0 0.0 0.0" scale="1 1 1" from="-6 6 6" to="0 0 0" cutoff="35" falloff="10" />

        <light_source type="spot" I="0.0 1.0 0.0" scale="1 1 1" from="6 6 6" to="0 0 0" cutoff="35" falloff="10" />

        <light_source type="spot" I="0.0 0.0 1.0" scale="1 1 1" from="0 6 -8" to="0 0 0" cutoff="35" falloff="10" />

        <make_named_material type="blinn" name="pure_matte_white" ambient="0 0 0" diffuse ="1.0 1.0 1.0" specular ="0.1 0.1 0.1" glossiness ="8"/>

        <named_material name="pure_matte_white"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <object type="cube" p1="-0.5 0 -0.5" p2="0.5 5 0.5" />

        <object type="sphere" center="0 5 0" radius="0.5" />

    <world_end/>
</RT3>
