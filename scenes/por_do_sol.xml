<RT3>
    <camera type="perspective" fovy="45" />
    <integrator type="blinn" depth="2" />
    <film type="image" w_res="1920" h_res="1200" filename="por_do_sol.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <!-- Céu: laranja/vermelho no horizonte, vermelho-escuro no topo -->
        <background type="colors" bl="230 90 20" tl="100 20 10" tr="100 20 10" br="230 90 20" />

        <!-- Ambient quente dourado -->
        <light_source type="ambient" I="0.4 0.18 0.05" scale="1.0 1.0 1.0" />

        <!-- Sol poente: luz rasante vinda da esquerda, quente e forte -->
        <light_source type="directional" I="1.0 0.6 0.2" scale="1.2 1.2 1.2" from="-10 1.5 -1" to="0 0 1" />

        <!-- Luz de preenchimento suave (reflexo do céu vermelho) -->
        <light_source type="point" I="0.8 0.25 0.1" scale="0.8 0.8 0.8" from="5 8 2" />

        <!-- ===== CHÃO: areia do deserto ===== -->
        <make_named_material type="blinn" name="desert_sand"
            ambient="0.25 0.15 0.06"
            diffuse="0.75 0.52 0.22"
            specular="0.15 0.12 0.08"
            glossiness="4"/>
        <named_material name="desert_sand"/>
        <object type="sphere" center="0 -5000 0" radius="5000" />

        <!-- ===== ESFERA CENTRAL: OURO puro ===== -->
        <!-- Grande, no centro, vai capturar highlights lindos com a luz rasante -->
        <make_named_material type="blinn" name="pure_gold"
            ambient="0.3 0.2 0.0"
            diffuse="1.0 0.72 0.1"
            specular="1.0 0.85 0.4"
            glossiness="512"/>
        <named_material name="pure_gold"/>
        <object type="sphere" center="0 2.0 3" radius="2.0" />

        <!-- ===== ESFERA ESQUERDA: COBRE ===== -->
        <make_named_material type="blinn" name="copper"
            ambient="0.2 0.1 0.04"
            diffuse="0.8 0.4 0.15"
            specular="0.9 0.55 0.3"
            glossiness="256"/>
        <named_material name="copper"/>
        <object type="sphere" center="-4.5 1.2 2" radius="1.2" />

        <!-- ===== ESFERA DIREITA: FERRO ESCURO / METEORITO ===== -->
        <make_named_material type="blinn" name="dark_iron"
            ambient="0.08 0.06 0.05"
            diffuse="0.3 0.25 0.22"
            specular="0.7 0.65 0.6"
            glossiness="128"/>
        <named_material name="dark_iron"/>
        <object type="sphere" center="5.5 1.5 1" radius="1.5" />

        <!-- ===== ESFERA FUNDO-ESQUERDA: BRONZE ===== -->
        <make_named_material type="blinn" name="bronze"
            ambient="0.18 0.12 0.04"
            diffuse="0.7 0.5 0.12"
            specular="0.6 0.45 0.2"
            glossiness="64"/>
        <named_material name="bronze"/>
        <object type="sphere" center="-7 1.0 8" radius="1.0" />

        <!-- ===== ESFERA FUNDO-DIREITA: PRATA ENVELHECIDA ===== -->
        <make_named_material type="blinn" name="aged_silver"
            ambient="0.15 0.12 0.1"
            diffuse="0.6 0.55 0.5"
            specular="0.85 0.8 0.75"
            glossiness="256"/>
        <named_material name="aged_silver"/>
        <object type="sphere" center="8 1.0 9" radius="1.0" />

        <!-- ===== PEDRAS PEQUENAS (debris de meteorito) ===== -->
        <make_named_material type="blinn" name="rock_dark"
            ambient="0.1 0.07 0.04"
            diffuse="0.38 0.28 0.18"
            specular="0.2 0.18 0.15"
            glossiness="8"/>
        <named_material name="rock_dark"/>
        <object type="sphere" center="-1.5 0.25 1.0" radius="0.25" />
        <object type="sphere" center=" 2.0 0.2  0.5" radius="0.2"  />
        <object type="sphere" center="-3.0 0.3  5.0" radius="0.3"  />
        <object type="sphere" center=" 4.0 0.18 6.0" radius="0.18" />
        <object type="sphere" center=" 1.0 0.15 7.5" radius="0.15" />

        <!-- ===== SOL NO CÉU: flat sphere no horizonte ===== -->
        <!-- Disco do sol no horizonte (aparência emissiva) -->
        <material type="flat" color="255 200 50" />
        <object type="sphere" center="-18 2 12" radius="1.8" />

        <!-- Halo do sol levemente mais escuro -->
        <material type="flat" color="255 130 20" />
        <object type="sphere" center="-18 2 12" radius="2.2" />

    <world_end/>
</RT3>
