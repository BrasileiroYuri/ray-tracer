<RT3>
    <lookat look_from="0 6 -18" look_at="0 2 0" up="0 1 0" />
    <camera type="perspective" fovy="45" />

    <integrator type="blinn_phong" depth="1" />

    <film type="image"
          w_res="1920"
          h_res="1080"
          filename="hall_spotlights.png"
          img_type="png"
          gamma_corrected="false" />

    <aggregator type="list"/>

    <world_begin/>

        <background type="4_colors"
            bl="10 10 20"
            tl="40 40 90"
            tr="40 40 90"
            br="10 10 20" />

        <light_source type="ambient"
            I="0.05 0.05 0.05"
            scale="1 1 1" />

        <!-- Red -->
        <light_source type="spot"
            I="1 0.2 0.2"
            scale="1 1 1"
            from="-6 8 0"
            to="-6 0 0"
            cutoff="20"
            falloff="10" />

        <!-- Green -->
        <light_source type="spot"
            I="0.2 1 0.2"
            scale="1 1 1"
            from="0 8 0"
            to="0 0 0"
            cutoff="20"
            falloff="10" />

        <!-- Blue -->
        <light_source type="spot"
            I="0.2 0.2 1"
            scale="1 1 1"
            from="6 8 0"
            to="6 0 0"
            cutoff="20"
            falloff="10" />

        <make_named_material type="blinn"
            name="mirror_red"
            ambient="0.2 0.2 0.2"
            diffuse="1 0.1 0.1"
            specular="1 1 1"
            glossiness="512"/>

        <make_named_material type="blinn"
            name="mirror_green"
            ambient="0.2 0.2 0.2"
            diffuse="0.1 1 0.1"
            specular="1 1 1"
            glossiness="512"/>

        <make_named_material type="blinn"
            name="mirror_blue"
            ambient="0.2 0.2 0.2"
            diffuse="0.1 0.1 1"
            specular="1 1 1"
            glossiness="512"/>

        <make_named_material type="blinn"
            name="floor"
            ambient="0.1 0.1 0.1"
            diffuse="0.8 0.8 0.8"
            specular="0 0 0"
            glossiness="0"/>

        <named_material name="mirror_red"/>
        <object type="sphere" center="-6 1 0" radius="1"/>

        <named_material name="mirror_green"/>
        <object type="sphere" center="0 1 0" radius="1"/>

        <named_material name="mirror_blue"/>
        <object type="sphere" center="6 1 0" radius="1"/>

        <named_material name="floor"/>
        <object type="plane" point="0 0 0" normal="0 1 0"/>

    <world_end/>
</RT3>
