<RT3>
    <lookat look_from="10 12 -18" look_at="0 4 0" up="0 1 0" />
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="3" />
    <film type="image" w_res="1920" h_res="1080" filename="monolith.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <background type="colors" bl="5 5 10" tl="0 0 0" tr="0 0 0" br="5 5 10" />

        <light_source type="ambient" I="2 2 5" scale="1 1 1" />
        <light_source type="directional" I="0.2 0.2 0.3" scale="1 1 1" from="10 20 -10" to="0 0 0" />
        <light_source type="point" I="0.0 0.8 1.0" scale="3.0 3.0 3.0" from="4.0 6.0 0.0" />
        <light_source type="point" I="1.0 0.0 0.5" scale="3.0 3.0 3.0" from="-2.0 6.0 3.5" />
        <light_source type="point" I="0.5 1.0 0.0" scale="3.0 3.0 3.0" from="-2.0 6.0 -3.5" />

        <make_named_material type="blinn" name="monolith_mat"
            ambient="0.01 0.01 0.01" diffuse="0.05 0.05 0.08" specular="0.9 0.9 0.9" glossiness="1024"/>
        <make_named_material type="blinn" name="floor_mat"
            ambient="0.05 0.05 0.05" diffuse="0.2 0.2 0.2" specular="0.5 0.5 0.5" glossiness="128"/>

        <named_material name="floor_mat"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <named_material name="monolith_mat"/>
        <object type="cube" p1="-2 0 -2" p2="2 12 2" />

        <object type="sphere" center="5.0 6.0 0.0" radius="1.2" />

        <named_material name="floor_mat"/>
        <object type="sphere" center="-2.5 6.0 4.33" radius="1.2" />

        <object type="sphere" center="-2.5 6.0 -4.33" radius="1.2" />

    <world_end/>
</RT3>
