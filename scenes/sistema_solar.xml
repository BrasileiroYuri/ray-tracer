<RT3>
    <camera type="perspective" fovy="45" />
    <integrator type="blinn" depth="2" />
    <film type="image" w_res="1920" h_res="1200" filename="sistema_solar.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <!-- Espaço: preto absoluto no centro, levemente azul nas bordas -->
        <background type="colors" bl="3 3 12" tl="1 1 6" tr="1 1 6" br="3 3 12" />

        <!-- Ambient mínimo (luz estelar difusa) -->
        <light_source type="ambient" I="0.04 0.04 0.06" scale="1 1 1" />

        <!-- SOL: luz forte e quente vindo da esquerda/cima -->
        <light_source type="directional" I="1.0 0.92 0.75" scale="1.5 1.5 1.5" from="-12 5 -5" to="0 0 1" />
        <!-- Ponto de luz posicionado no centro do sol (para highlights próximos) -->
        <light_source type="point" I="1.0 0.85 0.6" scale="3.0 3.0 3.0" from="-11 5 -3" />

        <!-- ===== "CHÃO" DO ESPAÇO: esfera invisível (diffuse=0) ===== -->
        <make_named_material type="blinn" name="void_space"
            ambient="0.0 0.0 0.0"
            diffuse="0.0 0.0 0.0"
            specular="0.0 0.0 0.0"
            glossiness="0"/>
        <named_material name="void_space"/>
        <object type="sphere" center="0 -5000 0" radius="5000" />

        <!-- ===== SOL (emissivo) ===== -->
        <material type="flat" color="255 230 60" />
        <object type="sphere" center="-11 5 -2" radius="3.8" />
        <!-- Halo solar (corona) -->
        <material type="flat" color="255 160 20" />
        <object type="sphere" center="-11 5 -2" radius="4.3" />

        <!-- ===== MERCÚRIO: pequeno, cinza rochoso, próximo ===== -->
        <make_named_material type="blinn" name="mercury"
            ambient="0.08 0.08 0.08"
            diffuse="0.42 0.38 0.34"
            specular="0.2 0.2 0.2"
            glossiness="16"/>
        <named_material name="mercury"/>
        <object type="sphere" center="-4.0 0.8 1" radius="0.3" />

        <!-- ===== VÊNUS: amarelado, atmosfera densa ===== -->
        <make_named_material type="blinn" name="venus"
            ambient="0.2 0.18 0.08"
            diffuse="0.88 0.82 0.48"
            specular="0.65 0.62 0.45"
            glossiness="32"/>
        <named_material name="venus"/>
        <object type="sphere" center="-1.5 0.9 2" radius="0.55" />

        <!-- ===== TERRA: azul oceano com verde ===== -->
        <make_named_material type="blinn" name="earth"
            ambient="0.05 0.12 0.2"
            diffuse="0.15 0.48 0.85"
            specular="0.8 0.85 0.95"
            glossiness="256"/>
        <named_material name="earth"/>
        <object type="sphere" center="1.5 1.1 4" radius="0.65" />

        <!-- LUA -->
        <make_named_material type="blinn" name="moon"
            ambient="0.08 0.08 0.08"
            diffuse="0.58 0.58 0.58"
            specular="0.12 0.12 0.12"
            glossiness="8"/>
        <named_material name="moon"/>
        <object type="sphere" center="2.5 1.5 3.4" radius="0.18" />

        <!-- ===== MARTE: vermelho-enferrujado ===== -->
        <make_named_material type="blinn" name="mars"
            ambient="0.18 0.06 0.03"
            diffuse="0.78 0.28 0.12"
            specular="0.25 0.15 0.1"
            glossiness="32"/>
        <named_material name="mars"/>
        <object type="sphere" center="4.5 0.9 6" radius="0.5" />

        <!-- ===== CINTURÃO DE ASTEROIDES ===== -->
        <make_named_material type="blinn" name="asteroid"
            ambient="0.06 0.05 0.04"
            diffuse="0.38 0.33 0.28"
            specular="0.08 0.08 0.07"
            glossiness="4"/>
        <named_material name="asteroid"/>
        <object type="sphere" center=" 6.5 0.7  8.0"  radius="0.14" />
        <object type="sphere" center=" 7.2 1.1  7.5"  radius="0.09" />
        <object type="sphere" center=" 6.0 0.5  9.2"  radius="0.11" />
        <object type="sphere" center=" 7.8 0.9  8.8"  radius="0.07" />
        <object type="sphere" center=" 6.8 1.3  10.0" radius="0.12" />
        <object type="sphere" center=" 8.2 0.6  9.5"  radius="0.08" />

        <!-- ===== JÚPITER: gigante laranja com faixas (simuladas por tamanho) ===== -->
        <make_named_material type="blinn" name="jupiter"
            ambient="0.18 0.13 0.08"
            diffuse="0.82 0.6 0.38"
            specular="0.5 0.4 0.28"
            glossiness="64"/>
        <named_material name="jupiter"/>
        <object type="sphere" center="13 3.0 12" radius="2.2" />

        <!-- Grande Mancha Vermelha de Júpiter (pequena esfera flat sobre a superfície) -->
        <material type="flat" color="180 60 40" />
        <object type="sphere" center="12.5 3.5 10.5" radius="0.45" />

        <!-- ===== SATURNO: dourado com "anel" (esferas finas ao redor) ===== -->
        <make_named_material type="blinn" name="saturn"
            ambient="0.2 0.16 0.08"
            diffuse="0.88 0.76 0.45"
            specular="0.6 0.52 0.32"
            glossiness="128"/>
        <named_material name="saturn"/>
        <object type="sphere" center="22 2.5 20" radius="1.8" />

        <!-- Anel de Saturno: esferas minúsculas numa linha horizontal -->
        <make_named_material type="blinn" name="ring_particle"
            ambient="0.15 0.12 0.09"
            diffuse="0.6 0.52 0.4"
            specular="0.3 0.28 0.22"
            glossiness="16"/>
        <named_material name="ring_particle"/>
        <object type="sphere" center="18.5 2.5 20" radius="0.12" />
        <object type="sphere" center="19.5 2.5 20" radius="0.15" />
        <object type="sphere" center="20.6 2.5 20" radius="0.1"  />
        <object type="sphere" center="23.4 2.5 20" radius="0.12" />
        <object type="sphere" center="24.5 2.5 20" radius="0.14" />
        <object type="sphere" center="25.4 2.5 20" radius="0.1"  />

        <!-- ===== CAMPO DE ESTRELAS ===== -->
        <!-- Estrelas brancas -->
        <material type="flat" color="255 255 255" />
        <object type="sphere" center="-8  9  20" radius="0.05" />
        <object type="sphere" center=" 3  11 18" radius="0.04" />
        <object type="sphere" center=" 9  7  22" radius="0.06" />
        <object type="sphere" center="-2  12 25" radius="0.04" />
        <object type="sphere" center=" 15 8  28" radius="0.05" />
        <object type="sphere" center="-6  6  30" radius="0.04" />
        <object type="sphere" center=" 18 10 24" radius="0.06" />
        <object type="sphere" center=" 0  14 20" radius="0.03" />
        <!-- Estrelas azul-brancas (quentes) -->
        <material type="flat" color="180 200 255" />
        <object type="sphere" center="-4  8  22" radius="0.05" />
        <object type="sphere" center=" 6  13 26" radius="0.04" />
        <object type="sphere" center="-10 5  19" radius="0.04" />
        <!-- Estrelas amareladas (tipo Sol) -->
        <material type="flat" color="255 240 180" />
        <object type="sphere" center=" 2  9  24" radius="0.04" />
        <object type="sphere" center="-7  11 28" radius="0.05" />
        <object type="sphere" center=" 12 6  32" radius="0.04" />

    <world_end/>
</RT3>
