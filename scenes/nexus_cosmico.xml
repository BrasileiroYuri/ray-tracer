<RT3>
    <lookat look_from="-15 10 -30" look_at="0 5 0" up="0 1 0" />
    <camera type="perspective" fovy="60" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="nexus_cosmico.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="0 0 5" tl="10 5 15" tr="15 10 20" br="5 0 10" />

        <light_source type="ambient" I="2 2 2" scale="1 1 1" />
        <light_source type="ambient" I="2 2 2" scale="1 1 1" />
        <light_source type="ambient" I="2 2 2" scale="1 1 1" />

        <light_source type="spot" I="1.2 1.1 1.4" scale="1 1 1" from="30 20 10" to="0 5 0" cutoff="15" falloff="5" />
        <light_source type="spot" I="1.2 1.0 1.4" scale="1 1 1" from="30 20 10" to="0 5 0" cutoff="15" falloff="5" />
        <light_source type="spot" I="1.2 1.0 1.4" scale="1 1 1" from="30 20 10" to="0 5 0" cutoff="15" falloff="5" />

        <light_source type="spot" I="1.4 1.6 1.2" scale="1 1 1" from="-30 -10 5" to="0 5 0" cutoff="20" falloff="10" />
        <light_source type="spot" I="1.4 0.6 1.2" scale="1 1 1" from="-30 -10 5" to="0 5 0" cutoff="20" falloff="10" />
        <light_source type="spot" I="1.4 1.6 1.2" scale="1 1 1" from="-30 -10 5" to="0 5 0" cutoff="20" falloff="10" />

        <light_source type="spot" I="1.0 1.1 1.1" scale="1 1 1" from="0 -15 20" to="0 5 -10" cutoff="15" falloff="5" />
        <light_source type="spot" I="1.0 0.1 1.1" scale="1 1 1" from="0 -15 20" to="0 5 -10" cutoff="15" falloff="5" />
        <light_source type="spot" I="1.0 1.1 0.1" scale="1 1 1" from="0 -15 20" to="0 5 -10" cutoff="15" falloff="5" />

        <make_named_material type="blinn" name="gas_giant" ambient="0.05 0.05 0.05" diffuse ="0.6 0.4 0.8" specular ="0.1 0.1 0.1" glossiness ="8"/>
        <make_named_material type="blinn" name="station_metal" ambient="0.1 0.1 0.1" diffuse ="0.7 0.7 0.7" specular ="0.9 0.9 0.9" glossiness ="256"/>
        <make_named_material type="blinn" name="ring_dust" ambient="0.1 0.1 0.1" diffuse ="0.4 0.3 0.2" specular ="0 0 0" glossiness ="0"/>

        <named_material name="gas_giant"/>
        <object type="sphere" center="0 5 0" radius="8.0" />

        <named_material name="ring_dust"/>
        <object type="plane" point="0 5 0" normal="0 1 0.1" /> <named_material name="station_metal"/>

        <object type="cube" p1="-12 4 -12" p2="-10 6 12" />
        <object type="cube" p1="10 4 -12" p2="12 6 12" />
        <object type="cube" p1="-12 4 -12" p2="12 6 -10" />
        <object type="cube" p1="-12 4 10" p2="12 6 12" />

        <object type="sphere" center="-11 5 11" radius="1.5" />
        <object type="sphere" center="11 5 -11" radius="1.5" />
        <object type="cube" p1="-11 6 10" p2="-10.8 12 11.2" />
        <object type="cube" p1="10.8 6 -11.2" p2="11 12 -10" />

        <object type="cube" p1="-5 2 -18" p2="-4.8 2.2 -17.8" />
        <object type="cube" p1="8 8 15" p2="8.2 8.2 15.2" />
