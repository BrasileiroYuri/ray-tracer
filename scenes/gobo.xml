<RT3>
    <lookat look_from="0 4 -12" look_at="0 1 5" up="0 1 0" />
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="gobo.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="2 2 2" tl="5 5 5" tr="5 5 5" br="2 2 2" />
        <light_source type="ambient" I="0.02 0.02 0.02" scale="0.1 0.1 0.1" />

        <light_source type="spot" I="1.2 0.5 0.1" scale="1 1 1" from="-8 8 -5" to="5 0 5" cutoff="40" falloff="5" />

        <light_source type="spot" I="0.6 0.1 1.2" scale="1 1 1" from="8 8 -5" to="-5 0 5" cutoff="40" falloff="5" />

        <make_named_material type="blinn" name="grey_floor" ambient="0.1 0.1 0.1" diffuse ="0.6 0.6 0.6" specular ="0.3 0.3 0.3" glossiness ="32"/>
        <make_named_material type="blinn" name="black_blocker" ambient="0 0 0" diffuse ="0.1 0.1 0.1" specular ="0.1 0.1 0.1" glossiness ="8"/>
        <make_named_material type="blinn" name="white_target" ambient="0 0 0" diffuse ="0.9 0.9 0.9" specular ="1.0 1.0 1.0" glossiness ="256"/>

        <named_material name="grey_floor"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <named_material name="black_blocker"/>
        <object type="cube" p1="-4 2 -2" p2="-2 4 -1" />
        <object type="cube" p1="-1 1 -2" p2="1 3 -1" />
        <object type="cube" p1="2 3 -2" p2="4 5 -1" />
        <object type="cube" p1="-3 5 -2" p2="-1 6 -1" />
        <object type="cube" p1="1 6 -2" p2="3 7 -1" />

        <named_material name="white_target"/>
        <object type="sphere" center="-2 1.5 6" radius="1.5" />
        <object type="cube" p1="1 0 5" p2="4 4 8" />

    <world_end/>
</RT3>
