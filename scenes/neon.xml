<RT3>
    <lookat look_from="-4 1.5 -8" look_at="2 1 2" up="0 1 0" />
    <camera type="perspective" fovy="55" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="cena12_neon.png" img_type="png" gamma_corrected="false" />

    <aggregator type="list"/>
    <world_begin/>

        <background type="4_colors" bl="0 0 0" tl="2 0 5" tr="0 4 4" br="0 0 0" />
        <light_source type="ambient" I="0.5 0.5 0.5" scale="1 1 1" />

        <light_source type="spot" I="0.1 1.0 1.0" scale="1 1 1" from="10 0.5 0" to="0 0 0" cutoff="45" falloff="15" />

        <light_source type="spot" I="1.0 0.0 0.8" scale="1 1 1" from="-5 2 -5" to="5 0 5" cutoff="35" falloff="10" />

        <make_named_material type="blinn" name="dark_plastic" ambient="0 0 0" diffuse ="0.05 0.05 0.05" specular ="1.0 1.0 1.0" glossiness ="512"/>
        <make_named_material type="blinn" name="floor_glossy" ambient="0 0 0" diffuse ="0.1 0.1 0.1" specular ="0.8 0.8 0.8" glossiness ="128"/>

        <named_material name="floor_glossy"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

        <named_material name="dark_plastic"/>

        <object type="cube" p1="0 0 0" p2="2 4 2" />
        <object type="sphere" center="1 4.5 1" radius="0.5" />

        <object type="cube" p1="-2 0 2" p2="-1 2 3" />
        <object type="cube" p1="3 0 -1" p2="4 6 1" />
        <object type="cube" p1="2 0 4" p2="5 1 6" />
        <object type="sphere" center="-2 1 -1" radius="1.0" />
        <object type="sphere" center="5 0.8 2" radius="0.8" />

    <world_end/>
</RT3>
