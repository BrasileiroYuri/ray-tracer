<RT3>
    <lookat look_from="0 10 -20" look_at="0 2 0" up="0 1 0" />
    <camera type="perspective" fovy="50" />
    <integrator type="blinn" depth="1" />
    <film type="image" w_res="1920" h_res="1080" filename="ambient.png" img_type="png" gamma_corrected="true" />

    <aggregator type="list"/>

    <world_begin/>
        <background type="colors" bl="5 5 15" tl="0 0 0" tr="0 0 0" br="5 5 15" />

        <light_source type="ambient" I="5 5 1" scale="1 1 1" />
        <light_source type="point" I="1 8 1" scale="1 1 1" from="-5 5 -5" /> <light_source type="point" I="1.0 0.0 0.8" scale="1 1 1" from="5 5 -5" />  <make_named_material name="neon_blue" ambient="0.1 0.4 0.8" diffuse="0.0 0.2 0.9" specular="0.9 0.9 0.9" glossiness="128"/>
        <make_named_material name="neon_pink" ambient="0.8 0.1 0.4" diffuse="0.9 0.1 0.2" specular="0.9 0.9 0.9" glossiness="128"/>
        <make_named_material name="dark_chrome" ambient="0.05 0.05 0.05" diffuse="0.1 0.1 0.1" specular="1 1 1" glossiness="512"/>

        <named_material name="dark_chrome"/>
        <object type="sphere" center="0 -5000 0" radius="5000" />

        <named_material name="neon_blue"/>
        <object type="sphere" center="-2 1.5 0" radius="1.5" />

        <named_material name="neon_pink"/>
        <object type="sphere" center="2 1.5 0" radius="1.5" />

        <material type="flat" color="0 255 255" />
        <object type="sphere" radius="0.2" center="0 5 2"/>
        <object type="sphere" radius="0.2" center="-1 6 3"/>
        <object type="sphere" radius="0.2" center="1 4 1"/>
    <world_end/>
</RT3>
