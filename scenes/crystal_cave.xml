<RT3>
    <camera type="perspective" fovy="45" />
    <integrator type="blinn" depth="3" />
    <film type="image" w_res="1920" h_res="1200" filename="crystal_cave.png" img_type="png" gamma_corrected="true" />
    <aggregator type="list"/>
    <world_begin/>

        <!-- Escuridão da caverna: preto total -->
        <background type="colors" bl="3 1 5" tl="1 0 3" tr="1 0 3" br="3 1 5" />

        <!-- Ambient mínimo -->
        <light_source type="ambient" I="0.04 0.02 0.06" scale="1 1 1" />

        <!-- Holofote branco de cima (como abertura na caverna) -->
        <light_source type="point" I="1.0 0.95 0.9" scale="5.0 5.0 5.0" from="0 12 4" />

        <!-- Luz colorida de cada cristal grande -->
        <light_source type="point" I="0.1 0.0 1.0"  scale="2.5 2.5 2.5" from="-5 2 3"  />  <!-- Safira -->
        <light_source type="point" I="1.0 0.1 0.1"  scale="2.5 2.5 2.5" from=" 5 2 3"  />  <!-- Rubi -->
        <light_source type="point" I="0.1 1.0 0.2"  scale="2.0 2.0 2.0" from=" 0 1 7"  />  <!-- Esmeralda -->
        <light_source type="point" I="0.9 0.7 0.0"  scale="2.0 2.0 2.0" from="-2 4 1"  />  <!-- Topázio -->
        <light_source type="point" I="0.8 0.0 0.8"  scale="1.5 1.5 1.5" from=" 3 3 1"  />  <!-- Ametista -->

        <!-- ===== CHÃO DA CAVERNA: pedra escura levemente reflexiva ===== -->
        <make_named_material type="blinn" name="cave_floor"
            ambient="0.04 0.03 0.05"
            diffuse="0.12 0.1  0.14"
            specular="0.55 0.5  0.6"
            glossiness="64"/>
        <named_material name="cave_floor"/>
        <object type="sphere" center="0 -5000 0" radius="5000" />

        <!-- ===== SAFIRA (azul royal, central) ===== -->
        <make_named_material type="blinn" name="sapphire"
            ambient="0.02 0.02 0.25"
            diffuse="0.05 0.08 0.85"
            specular="0.95 0.95 1.0"
            glossiness="2048"/>
        <named_material name="sapphire"/>
        <object type="sphere" center="-5 2.0 3" radius="1.8" />

        <!-- ===== RUBI (vermelho profundo) ===== -->
        <make_named_material type="blinn" name="ruby"
            ambient="0.25 0.01 0.01"
            diffuse="0.88 0.04 0.04"
            specular="1.0 0.88 0.88"
            glossiness="2048"/>
        <named_material name="ruby"/>
        <object type="sphere" center="5 2.0 3" radius="1.8" />

        <!-- ===== ESMERALDA (verde translúcida) ===== -->
        <make_named_material type="blinn" name="emerald"
            ambient="0.02 0.22 0.04"
            diffuse="0.04 0.82 0.12"
            specular="0.88 1.0 0.9"
            glossiness="1024"/>
        <named_material name="emerald"/>
        <object type="sphere" center="0 1.8 7" radius="1.5" />

        <!-- ===== TOPÁZIO (amarelo dourado) ===== -->
        <make_named_material type="blinn" name="topaz"
            ambient="0.22 0.16 0.0"
            diffuse="0.9 0.72 0.08"
            specular="1.0 0.95 0.7"
            glossiness="1024"/>
        <named_material name="topaz"/>
        <object type="sphere" center="-2.5 3.5 1" radius="1.0" />

        <!-- ===== AMETISTA (violeta) ===== -->
        <make_named_material type="blinn" name="amethyst"
            ambient="0.2 0.02 0.22"
            diffuse="0.62 0.08 0.72"
            specular="0.95 0.85 1.0"
            glossiness="1024"/>
        <named_material name="amethyst"/>
        <object type="sphere" center="3.5 2.5 1" radius="1.1" />

        <!-- ===== DIAMANTE CENTRAL (incolor, ultra-reflexivo) ===== -->
        <!-- No centro, no topo, onde a luz do holofote bate diretamente -->
        <make_named_material type="blinn" name="diamond"
            ambient="0.08 0.08 0.1"
            diffuse="0.12 0.12 0.15"
            specular="1.0 1.0 1.0"
            glossiness="4096"/>
        <named_material name="diamond"/>
        <object type="sphere" center="0 3.5 4" radius="1.2" />

        <!-- ===== CRISTAIS MENORES (fragmentos) ===== -->
        <!-- Quartzo rosa -->
        <make_named_material type="blinn" name="rose_quartz"
            ambient="0.22 0.08 0.1"
            diffuse="0.88 0.42 0.52"
            specular="0.9 0.8 0.85"
            glossiness="512"/>
        <named_material name="rose_quartz"/>
        <object type="sphere" center="-7.5 0.5 5"  radius="0.55" />
        <object type="sphere" center=" 7.0 0.6 4.5" radius="0.45" />
        <object type="sphere" center=" 0.5 0.4 9"   radius="0.5"  />

        <!-- Cristais brancos (calcita) -->
        <make_named_material type="blinn" name="calcite"
            ambient="0.18 0.18 0.18"
            diffuse="0.72 0.72 0.72"
            specular="0.95 0.95 0.95"
            glossiness="256"/>
        <named_material name="calcite"/>
        <object type="sphere" center="-3.5 0.3 6"  radius="0.4"  />
        <object type="sphere" center=" 2.5 0.35 8" radius="0.35" />
        <object type="sphere" center="-1.5 0.25 1" radius="0.3"  />
        <object type="sphere" center=" 4.5 0.3 6"  radius="0.38" />

        <!-- ===== PONTOS DE LUZ EMISSIVOS (flat spheres para indicar a fonte) ===== -->
        <material type="flat" color="255 255 240" />
        <object type="sphere" center="0 12 4" radius="0.3" />

    <world_end/>
</RT3>
